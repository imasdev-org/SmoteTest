{
  "name": "smotetest",
  "version": "1.0.0",
  "description": "Repositorio para guardar el smoke test automatizado",
  "main": "index.js",
  "scripts": {
    "bddgen": "npx bddgen",
    "test": "npx bddgen && playwright test",
    "test:trunk": "npx bddgen && playwright test --project='trunk-desktop' --project='trunk-mobile'",
    "test:staging": "npx bddgen && playwright test --project='staging-desktop' --project='staging-mobile'",
    "test:preprod": "npx bddgen && playwright test --project='preprod-desktop' --project='preprod-mobile'",
    "test:prod": "npx bddgen && playwright test --project='prod-desktop' --project='prod-mobile'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imasdev-org/SmoteTest.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/imasdev-org/SmoteTest/issues"
  },
  "homepage": "https://github.com/imasdev-org/SmoteTest#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright-bdd": "^8.5.0",
    "typescript": "^6.0.2"
  }
}
